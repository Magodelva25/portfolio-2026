---
import "../../styles/globals.css";
import Accordion from "../UI/accordion.astro";
import proyectos from "../../data/proccess.json";
---

<section id="container" class="w-full h-auto bg-black px-5 pt-30 flex flex-col">
  <div class="flex flex-col justify-end">
    <h2 class="text-white pb-5 md:max-w-1/2">
      Here’s my
      <span class="text-[#FCEC00]">proccess</span>
    </h2>
    <p class="description text-white">
      Let’s deep dive into my workflow
    </p>
  </div>

  <div class="text-white py-10">
    {proyectos.map((p, index) => (
      <Accordion
        key={index}
        title={p.title}
        description={p.description}
        tags={p.tags}
      />
    ))}
  </div>
</section>

<style>
  h2 {
    font-family: Inter;
    font-weight: 500;
    font-size: 3rem;
    line-height: 1;
    letter-spacing: -0.05em;
  }
  .description {
    font-family: Inter;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.3;
  }
</style>
