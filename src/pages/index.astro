---
import Layout from './../layout/layout.astro';
import ProccessCard from '../components/UI/processCard.astro';
import projects from "../data/projects.json";
import proccess from "../data/proccess.json";
import ProjectCard from '../components/UI/projectCard.astro';
import './../styles/globals.css';
---

<Layout>

<div id="smooth-wrapper">
  <div id="smooth-content">

    <main id="container">

      <section id="hero" class="section absolute top-0 h-dvh rounded-3xl w-full items-center bg-black/25 backdrop-blur-2xl px-5 flex z-60 bg-[url('/foto-principal.jpg')] bg-cover bg-center grayscale-100 overflow-hidden">
          <div id="title-wrapper" class="fixed bottom-10 left-0 w-full px-5 z-50 flex justify-between opacity-100">
              <h1 id="title" class="relative text-white w-[60%] leading-none">
                  Full Stack Developer<br />UX/UI Designer
              </h1>
              <span id="location" class="flex relative text-white items-end font-bold text-[1rem]">
                  Based in Spain
              </span>
          </div>
      </section>

      <section id="about" class="section absolute top-0 h-screen rounded-t-3xl w-full items-center bg-black/25 backdrop-blur-2xl px-5 flex z-50">
          <div id="about-title" class="flex flex-col w-2/3 relative left-[-100px]">
              <h2 class="text-white pb-5">
                  Design & Development
                  <span class="text-[#FCEC00]">to tackle</span> real world problems
              </h2>
              <p class="description text-white md:max-w-2/3">
                  With experience across design, UX/UI, and web development.
                  I understand the full creative process and enjoy structure, planning, and problem‑solving.
              </p>
          </div>
      </section>

      <section id="proccess" class="section absolute top-0 h-250 w-full rounded-3xl bg-black/25 backdrop-blur-2xl px-5 pt-20 mb-20 z-40">
          <div class="flex flex-col w-full z-20">
              <h2 class="text-white pb-5">
                  Here's my <span class="text-[#FCEC00]">process</span>
              </h2>
              <p class="description text-white">Let's deep dive into my workflow</p>

              <div class="projects-gallery grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5 pt-10 z-30">
                  {proccess.map((p, index) => (
                      <ProccessCard
                          key={index}
                          title={p.title}
                          description={p.description}
                          tags={p.tags}
                      />
                  ))}
              </div>
          </div>
      </section>

      <section id="projects" class="section absolute top-0 h-auto w-full rounded-3xl bg-black/25 backdrop-blur-2xl px-5 pb-20 mb-20 flex z-30"> 
          <div class="flex flex-col w-full">
              <h2 class="text-white pt-20">
                  Some <span class="text-[#FCEC00]">projects</span>
              </h2>

              <div class="projects-gallery grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5 pt-10 z-30">
                  {projects.map((p, index) => (
                      <ProjectCard
                          key={index}
                          fecha={p.fecha}
                          cliente={p.cliente}
                          imageUrl={p.imageUrl}
                          imgAlt={p.imgAlt}
                          titulo={p.titulo}
                          descripcion={p.descripcion}
                          tags={p.tags}
                          slugs={p.slug}
                      />
                  ))}
              </div>
          </div>
      </section>


      <section id="contact" class="section absolute top-0 h-192 w-full rounded-t-3xl bg-black/25 backdrop-blur-2xl px-5 items-center justify-between pb-10 z-10">
          <h2 class="contact-title text-white self-end text-6xl w-2/3 wrap-break fixed bottom-5 z-50">Shall we talk ?</h2>
          <div class="flex flex-col-reverse items-end gap-2 self-end align-bottom z-50">
              <span class="text-white">LinkedIn</span>
              <span class="text-white">Email</span>
          </div>
      </section>

    </main>

  </div>
</div>

</Layout>

<style>
    html { overflow-x: hidden; }
    .section { width: 100%; }

    h1, h2, span, p { font-family: Inter, sans-serif; }

    h1 {
        font-size: clamp(3rem, 5vw, 5rem);
        font-weight: 500;
        letter-spacing: -0.04em;
    }

    h2 {
        font-weight: 500;
        font-size: clamp(3rem, 6vw, 10rem);
        line-height: 1;
        letter-spacing: -0.05em;
    }

    .contact-title {
        font-size: clamp(8rem, 15vw, 15rem);
    }

    .description {
        font-weight: 400;
        font-size: 1rem;
        line-height: 1.3;
    }
</style>

<script>
import { gsap } from "gsap";
import { ScrollTrigger } from "gsap/ScrollTrigger";
import { ScrollSmoother } from "gsap/ScrollSmoother";

gsap.registerPlugin(ScrollTrigger, ScrollSmoother);

// ScrollSmoother necesita wrapper + content
const smoother = ScrollSmoother.create({
  wrapper: "#smooth-wrapper",
  content: "#smooth-content",
  smooth: 1.2,
  effects: true,
});

// Timeline principal
const tl = gsap.timeline()
  .to("#hero", {
    top: "-100vh",
    duration: 0.5,
    ease: "power2.out",
  })
  .to("#title-wrapper > #title", {
    left: "-100vw",
    duration: 1,
    ease: "power2.out",
  }, "<")
  .to("#title-wrapper > #location", {
    right: "-100vw",
    duration: 1,
    ease: "power2.out",
  }, "<")
  .to("#about > #about-title", {
    left: "100px",
    duration: 1,
    ease: "circ.out",
  }, "<")
  .to("#about", {
    top: "-100vh",
    duration: 2,
    ease: "circ.out",
  })
  .to("#proccess", {
    left: "-150vw",
    duration: 2,
    ease: "circ.out",
  })
  .to("#projects", {
    top: "-150vh",
    duration: 2,
    ease: "circ.out",
  })
  .to("#about-me", {
    top: "-100vh",
    duration: 2,
    ease: "circ.out",
  });


// ScrollTrigger sincronizado con smoother
ScrollTrigger.create({
  animation: tl,
  trigger: "#container",
  start: "top top",
  end: "+=10000",
  scrub: true,
  pin: true,
});
</script>
