---
import Layout from '../layouts/Layout.astro';
import Accordion from '../components/UI/accordion.astro';
import projects from "../data/projects.json";
import ProjectCard from '../components/UI/projectCard.astro';
import './../styles/globals.css';
---

<Layout>

<!-- ===================== LOADER ===================== -->
<div id="loader" class="fixed inset-0 bg-black z-200 flex items-center justify-center">
    <div class="flex flex-col items-center gap-6">
        <p id="loader-name" class="text-white text-[1rem] tracking-[0.4em] uppercase opacity-0">
            Tu Nombre
        </p>
        <div class="w-48 overflow-hidden" style="height:1px; background: rgba(255,255,255,0.2)">
            <div id="loader-bar" class="h-full bg-[#FCEC00] w-0"></div>
        </div>
        <span id="loader-count" class="text-white/40 text-xs tabular-nums">0</span>
    </div>
</div>

<!-- ===================== INTRO SPACER ===================== -->
<div id="intro-spacer" style="height: 500vh; position: relative;">

    <!-- Fondo negro base -->
    <div class="fixed inset-0 bg-black z-10"></div>

    <!-- Foto con máscara SVG -->
    <div
        id="mask-wrapper"
        class="fixed inset-0 z-20"
        style="mask-image: url('/square.svg'); mask-repeat: no-repeat; mask-position: center center; mask-size: 0%;"
    >
        <picture
            id="hero-key"
            class="absolute inset-0 overflow-hidden"
            style="transform: scale(1.25); transform-origin: center center;"
        >
            <img
                src="/foto-principal.jpg"
                alt="foto-principal"
                class="w-full h-full object-cover grayscale"
            />
        </picture>
    </div>

    <!-- Overlay negro encima de la foto -->
    <div id="bg-negro" class="fixed inset-0 bg-black z-30 opacity-0 pointer-events-none"></div>

    <!-- Logo central -->
    <div id="logo-center" class="fixed inset-0 z-40 flex items-center justify-center opacity-0">
        <p id="logo-name" class="text-white text-[4rem] tracking-[0.5em] uppercase font-light">MIAGO</p>
    </div>

    <!-- H1 anclado al bottom — sin transform inline, GSAP lo maneja -->
    <div
        id="title-wrapper"
        class="fixed bottom-5 left-0 w-full px-5 pb-10 z-50 flex justify-between"
    >
        <h1 id="title" class="text-white w-[60%] leading-none opacity-0">
            Full Stack Developer<br />UX/UI Designer
        </h1>
        <span id="location" class="flex text-white items-end font-bold text-[1rem] opacity-0">
            Based in Spain
        </span>
    </div>

</div>

<div id="sections-wrapper" style="height: 600vh; position: relative;">

    <section id="about" class="section sticky top-0 h-screen w-full bg-black px-5 flex items-center" style="z-index: 20;">
        <div class="flex flex-col w-full">
            <h2 class="text-white pb-5">
                Design & Development
                <span class="text-[#FCEC00]">to tackle</span> real world problems
            </h2>
            <p class="description text-white md:max-w-2/3">
                With experience across design, UX/UI, and web development.
                I understand the full creative process and enjoy structure, planning, and problem‑solving.
            </p>
        </div>
    </section>

    <section id="proccess" class="section sticky top-0 h-screen w-full bg-black px-5 flex items-center" style="z-index: 20;">
        <div class="flex flex-col w-full">
            <h2 class="text-white pb-5">
                Here's my <span class="text-[#FCEC00]">process</span>
            </h2>
            <p class="description text-white">Let's deep dive into my workflow</p>
            <div class="text-white py-10">
                {projects.map((p, index) => (
                    <Accordion key={index} title={p.titulo} description={p.descripcion} tags={p.tags} />
                ))}
            </div>
        </div>
    </section>

    <section id="projects" class="section sticky top-0 h-screen w-full bg-black px-5 flex items-center" style="z-index: 30;">
        <div class="flex flex-col w-full">
            <h2 class="text-white pb-5">
                Some <span class="text-[#FCEC00]">projects</span>
            </h2>
            <div class="projects-gallery grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5 pt-10">
                {projects.map((p, index) => (
                    <ProjectCard
                        key={index}
                        fecha={p.fecha}
                        cliente={p.cliente}
                        imageUrl={p.imageUrl}
                        imgAlt={p.imgAlt}
                        titulo={p.titulo}
                        descripcion={p.descripcion}
                        tags={p.tags}
                        slugs={p.slug}
                    />
                ))}
            </div>
        </div>
    </section>

    <section id="about-me" class="section sticky top-0 h-screen w-full bg-black px-5 flex items-center" style="z-index: 40;">
        <div class="flex flex-col w-full">
            <h2 class="pb-5">
                <span class="text-[#FCEC00]">About</span>
                <span class="text-white"> me</span>
            </h2>
        </div>
    </section>

    <section id="contact" class="section sticky top-0 h-screen w-full bg-black px-5 flex items-center justify-between" style="z-index: 50;">
        <h2 class="text-white">Shall we talk?</h2>
        <div class="flex flex-col-reverse items-end gap-2">
            <span class="text-white">LinkedIn</span>
            <span class="text-white">Email</span>
        </div>
    </section>

</div>

<!-- ===================== SCROLL INDICATOR ===================== -->
<div
    id="scroll-indicator"
    class="fixed bottom-8 z-100 flex flex-col items-center gap-2 opacity-0"
    style="left: 50%; transform: translateX(-50%) translateY(10px);"
>
    <span class="text-white/50 text-xs tracking-[0.3em] uppercase">Scroll</span>
    <div class="overflow-hidden relative" style="width:1px; height: 40px; background: rgba(255,255,255,0.2)">
        <div class="absolute top-0 left-0 w-full h-full bg-[#FCEC00] animate-scroll-line"></div>
    </div>
</div>

</Layout>

<style>
    html {
        overflow-x: hidden;
    }

    body.is-loading {
        overflow: hidden;
    }

    /* CRÍTICO: no poner position aquí, interfiere con sticky de Tailwind */
    .section {
        width: 100%;
    }

    h1, h2, span, p {
        font-family: Inter, sans-serif;
    }

    h1 {
        font-size: clamp(3rem, 5vw, 5rem);
        font-weight: 500;
        letter-spacing: -0.04em;
    }

    h2 {
        font-weight: 500;
        font-size: clamp(3rem, 6vw, 7rem);
        line-height: 1;
        letter-spacing: -0.05em;
    }

    .description {
        font-weight: 400;
        font-size: 1rem;
        line-height: 1.3;
    }

    #logo-name {
        font-family: Inter;
        font-weight: 700;
    }

    @keyframes scrollLine {
        0%   { transform: translateY(-100%); }
        100% { transform: translateY(100%); }
    }
    .animate-scroll-line {
        animation: scrollLine 1.4s ease-in-out infinite;
    }
</style>

<script>
import { gsap } from "gsap";
import { ScrollTrigger } from "gsap/ScrollTrigger";

gsap.registerPlugin(ScrollTrigger);

// =========================
// SPLIT TEXT — carácter por carácter
// Respeta nodos de texto plano y spans con color (ej. amarillo)
// =========================

function splitToChars(selector: string) {
    const els = document.querySelectorAll<HTMLElement>(selector);
    els.forEach(el => {
        const nodes = Array.from(el.childNodes);
        el.innerHTML = "";

        nodes.forEach(node => {
            if (node.nodeType === Node.TEXT_NODE) {
                const text = node.textContent || "";
                text.split("").forEach(char => {
                    const span = document.createElement("span");
                    span.textContent = char === " " ? "\u00A0" : char;
                    span.style.display = "inline-block";
                    span.style.opacity = "0";
                    span.style.transform = "translateY(14px)";
                    el.appendChild(span);
                });
            } else if (node.nodeType === Node.ELEMENT_NODE) {
                const elem = node as HTMLElement;
                const text = elem.textContent || "";
                // wrapper para mantener el salto de línea implícito del span
                const wrapper = document.createElement("span");
                wrapper.style.display = "inline";
                text.split("").forEach(char => {
                    const span = document.createElement("span");
                    span.textContent = char === " " ? "\u00A0" : char;
                    span.style.display = "inline-block";
                    span.style.opacity = "0";
                    span.style.transform = "translateY(14px)";
                    // Copia clases de color (text-[#FCEC00] etc.)
                    elem.classList.forEach(c => span.classList.add(c));
                    wrapper.appendChild(span);
                });
                el.appendChild(wrapper);
            }
        });
    });
}

function animateChars(sectionEl: HTMLElement) {
    const chars = sectionEl.querySelectorAll<HTMLElement>("h2 span");
    if (!chars.length) return;

    gsap.to(chars, {
        opacity: 1,
        y: 0,
        duration: 0.025,
        stagger: 0.022,
        ease: "none",
        scrollTrigger: {
            trigger: sectionEl,
            start: "top 85%",
            toggleActions: "play none none reverse",
        }
    });
}

// Aplica split antes de cualquier animación
splitToChars(".section h2");

// =========================
// LOADER + INTRO AUTOMÁTICO
// =========================

const maskWrapper = document.getElementById("mask-wrapper");

function setMaskSize(pct: number) {
    if (maskWrapper) maskWrapper.style.maskSize = `${pct}%`;
}

document.body.classList.add("is-loading");

const introTL = gsap.timeline({
    onComplete: () => {
        document.body.classList.remove("is-loading");

        // Muestra el scroll indicator con entrada suave
        gsap.to("#scroll-indicator", {
            opacity: 1,
            y: 0,
            duration: 0.8,
            ease: "power2.out"
        });

        // Oculta el indicator al primer scroll real
        ScrollTrigger.create({
            trigger: "#intro-spacer",
            start: "top+=100 top",
            onEnter:     () => gsap.to("#scroll-indicator", { opacity: 0, duration: 0.4 }),
            onLeaveBack: () => gsap.to("#scroll-indicator", { opacity: 1, duration: 0.4 }),
        });
    }
});

introTL
    .to("#loader-name", { opacity: 1, duration: 0.4 })
    .to("#loader-bar",  { width: "100%", duration: 1.2 }, "<")
    .to({}, {
        duration: 1.2,
        onUpdate() {
            const el = document.getElementById("loader-count");
            if (el) el.textContent = String(Math.round(this.progress() * 100));
        }
    }, "<")
    .to("#loader", {
        opacity: 0,
        duration: 0.5,
        onComplete: () => {
            const loader = document.getElementById("loader");
            if (loader) loader.style.display = "none";
        }
    })
    .to("#hero-key", { scale: 1, duration: 2, ease: "circ.out" }, "<")
    .to({}, {
        duration: 2,
        ease: "power2.inOut",
        onUpdate() {
            setMaskSize(this.progress() * 160);
        }
    }, 0);

// =========================
// SCROLL INTRO TIMELINE
// Controlado por scroll dentro del #intro-spacer (500vh)
// =========================

const scrollTL = gsap.timeline({
    scrollTrigger: {
        trigger: "#intro-spacer",
        start: "top top",
        end: "bottom top",
        scrub: true,
    }
});

scrollTL
    .fromTo("#logo-center",
        { opacity: 0, y: 0 },
        { opacity: 1, duration: 1 }
    )
    .to("#logo-center", { opacity: 0, y: -30, duration: 1 })
    .to("#bg-negro",    { opacity: 1, duration: 2 })
    .fromTo("#title",    { opacity: 0, y: 40 }, { opacity: 1, y: 0, duration: 2 }, "<")
    .fromTo("#location", { opacity: 0, y: 40 }, { opacity: 1, y: 0, duration: 2 }, "<");

// Title y location salen al FINAL del intro-spacer, antes de que empiece el stack
gsap.to("#title, #location", {
    scrollTrigger: {
        trigger: "#intro-spacer",
        start: "85% top",     // empieza a salir en el 85% del spacer
        end: "bottom top",    // termina cuando el spacer abandona el viewport
        scrub: true,
    },
    y: -80,
    opacity: 0,
});

// =========================
// STACK ENTRY
// Cada sección entra desde ligeramente abajo (z-index ascendente en HTML)
// =========================

const sections = gsap.utils.toArray<HTMLElement>(".section");

sections.forEach((section, i) => {
    // Anima chars del h2 de cada sección
    animateChars(section);

    // La primera sección no necesita animación de entrada
    if (i === 0) return;

    gsap.fromTo(section,
        { yPercent: 4, opacity: 0 },
        {
            yPercent: 0,
            opacity: 1,
            ease: "none",
            scrollTrigger: {
                trigger: section,
                start: "top bottom",  // cuando el top de la sección toca el bottom del viewport
                end: "top top",       // cuando está completamente asentada
                scrub: true,
            }
        }
    );
});
</script>