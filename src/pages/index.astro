---
import Layout from '../layouts/Layout.astro';
import ProcessCard from '../components/UI/processCard.astro';
import projects from "../data/projects.json";
import proccess from "../data/proccess.json";
import ProjectCard from '../components/UI/projectCard.astro';
import './../styles/globals.css';
---

<Layout>

<!-- ===================== LOADER ===================== -->
<!-- <div id="loader" class="fixed inset-0 bg-black z-200 flex items-center justify-center">
    <div class="flex flex-col items-center gap-6">
        <p id="loader-name" class="text-white text-[1rem] tracking-[0.4em] uppercase opacity-0">
            Tu Nombre
        </p>
        <div class="w-48 overflow-hidden" style="height:1px; background: rgba(255,255,255,0.2)">
            <div id="loader-bar" class="h-full bg-[#FCEC00] w-0"></div>
        </div>
        <span id="loader-count" class="text-white/40 text-xs tabular-nums">0</span>
    </div>
</div> -->

<!-- ===================== WRAPPER GLOBAL ===================== -->
    <div id="intro-spacer" class="relative top-0 h-screen w-full z-5">
        <div
            id="mask-wrapper"
        >
            <picture
                id="hero-key"
                class="fixed inset-0 overflow-hidden"
                style="transform: scale(1.25); transform-origin: center center;"
            >
                <img
                    src="/foto-principal.jpg"
                    alt="foto-principal"
                    class="w-full h-full object-cover grayscale"
                />
            </picture>
        </div>

        <!-- Logo central -->
        <div id="logo-center" class="fixed inset-0 z-40 flex items-center justify-center opacity-0">
            <p id="logo-name" class="text-white text-[4rem] tracking-[0.5em] uppercase font-light">MIAGO</p>
        </div>

        <div
            id="title-wrapper"
            class="fixed bottom-5 left-0 w-full px-5 pb-9 z-50 flex justify-between"
        >
            <h1 id="title" class="text-white w-[60%] leading-none">
                Full Stack Developer<br />UX/UI Designer
            </h1>
            <span id="location" class="flex text-white items-end font-bold text-[1rem]">
                Based in Spain
            </span>
        </div>

    </div>

    <section id="about" class="section sticky top-0 h-screen rounded-t-3xl w-full items-center bg-black/25 backdrop-blur-2xl px-5 flex z-10">
        <div class="flex flex-col w-2/3">
            <h2 class="text-white pb-5">
                Design & Development
                <span class="text-[#FCEC00]">to tackle</span> real world problems
            </h2>
            <p class="description text-white md:max-w-2/3">
                With experience across design, UX/UI, and web development.
                I understand the full creative process and enjoy structure, planning, and problem‑solving.
            </p>
        </div>
    </section>

    <section id="proccess" class="section relative top-0 h-250 w-full rounded-3xl bg-black/25 backdrop-blur-2xl px-5 pt-20 mb-20 z-20">
        <div class="flex flex-col w-full z-20">
            <h2 class="text-white pb-5">
                Here's my <span class="text-[#FCEC00]">process</span>
            </h2>
            <p class="description text-white">Let's deep dive into my workflow</p>
            <div class="text-white py-10">
                <div class="projects-gallery grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5 pt-10 z-30">
                {proccess.map((p, index) => (
                    <ProcessCard
                        key={index}
                        title={p.title}
                        description={p.description}
                        tags={p.tags}
                    />
                ))}
            </div>
            </div>
        </div>
    </section>

    <section id="projects" class="section relative top-0 h-auto w-full rounded-3xl bg-black/25 backdrop-blur-2xl px-5 pb-20 mb-20 flex z-30"> 
        <div class="flex flex-col w-full">
            <h2 class="text-white pt-20">
                Some <span class="text-[#FCEC00]">projects</span>
            </h2>
            <div class="projects-gallery grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5 pt-10 z-30">
                {projects.map((p, index) => (
                    <ProjectCard
                        key={index}
                        fecha={p.fecha}
                        cliente={p.cliente}
                        imageUrl={p.imageUrl}
                        imgAlt={p.imgAlt}
                        titulo={p.titulo}
                        descripcion={p.descripcion}
                        tags={p.tags}
                        slugs={p.slug}
                    />
                ))}
            </div>
        </div>
    </section>

    <section id="about-me" class="section sticky top-0 h-220 w-full rounded-t-3xl bg-black/25 backdrop-blur-2xl px-5 flex items-center z-40"
        <div class="flex flex-col w-full">
            <h2 class="pb-5">
                <span class="text-[#FCEC00]">About</span>
                <span class="text-white"> me</span>
            </h2>
        </div>
    </section>

    <section id="contact" class="section sticky top-0 h-192 w-full rounded-t-3xl bg-black/25 backdrop-blur-2xl px-5 items-center justify-between pb-10 z-50">
        <h2 class="contact-title text-white self-end text-6xl w-2/3 wrap-break fixed bottom-5 z-50">Shall we talk ?</h2>
        <div class="flex flex-col-reverse items-end gap-2 self-end align-bottom z-50">
            <span class="text-white">LinkedIn</span>
            <span class="text-white">Email</span>
        </div>
    </section>

<div
    id="scroll-indicator"
    class="fixed bottom-8 z-100 flex flex-col items-center gap-2 opacity-0"
    style="left: 50%; transform: translateX(-50%) translateY(10px);"
>
    <span class="text-white/50 text-xs tracking-[0.3em] uppercase">Scroll</span>
    <div class="overflow-hidden relative" style="width:1px; height: 40px; background: rgba(255,255,255,0.2)">
        <div class="absolute top-0 left-0 w-full h-full bg-[#FCEC00] animate-scroll-line"></div>
    </div>
</div>

</Layout>

<style>
    html {
        overflow-x: hidden;
    }

    .section {
        width: 100%;
    }

    h1, h2, span, p {
        font-family: Inter, sans-serif;
    }

    h1 {
        font-size: clamp(3rem, 5vw, 5rem);
        font-weight: 500;
        letter-spacing: -0.04em;
    }

    h2 {
        font-weight: 500;
        font-size: clamp(3rem, 6vw, 10rem);
        line-height: 1;
        letter-spacing: -0.05em;
    }
    .contact-title{
        font-size: clamp(8rem, 15vw, 15rem);
    }

    .description {
        font-weight: 400;
        font-size: 1rem;
        line-height: 1.3;
    }

    #logo-name {
        font-family: Inter;
        font-weight: 700;
    }

</style>

<script>
</script>