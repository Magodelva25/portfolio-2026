---
import Layout from "../../layout/layout.astro";
import projects from "../../data/projects.json";

export function getStaticPaths() {
  return projects.map((p) => ({
    params: { project: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const pageTitle = `${project.titulo} — MANGO`;
---

<Layout title={pageTitle} description={project.descripcion}>
  <main class="min-h-dvh py-10 px-5">
    <article
      class="mx-auto max-w-5xl rounded-2xl bg-gray-950 overflow-hidden"
      transition:name={`project-${project.slug}`}
    >
      <img
        src={project.imageUrl}
        alt={project.imgAlt}
        width={1600}
        height={900}
        decoding="async"
        fetchpriority="high"
        class="w-full h-auto object-cover aspect-video"
      />

      <div class="p-10">
        <h1 class="text-white text-5xl font-bold drop-shadow-lg">
          {project.titulo}
        </h1>
        <p class="text-white text-lg mt-4 max-w-2xl drop-shadow-md">
          {project.descripcion}
        </p>
      </div>
    </article>
  </main>
</Layout>
