---
import Layout from "../../layout/layout.astro";
import projects from "../../data/projects.json";

export function getStaticPaths() {
  return projects.map((p) => ({
    params: { project: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const pageTitle = `${project.titulo} — MANGO`;
---

<Layout title={pageTitle} description={project.descripcion}>
  <main class="min-h-dvh py-10 px-5 relative bg-black">
    
    <div class="mx-auto max-w-5xl mb-6">
      <a 
        href="/" 
        class="inline-flex items-center gap-2 text-white/70 hover:text-white duration-300"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-1 transition-transform">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        <span class="font-medium">Volver</span>
      </a>
    </div>

    <article class="mx-auto max-w-5xl rounded-2xl bg-gray-950 overflow-hidden shadow-2xl">
      <img
        src={project.imageUrl}
        alt={project.imgAlt}
        width={1600}
        height={900}
        class="w-full h-auto object-cover aspect-video"
      />

      <div class="p-10">
        <h1 class="text-white text-5xl font-bold leading-tight">
          {project.titulo}
        </h1>
        <p class="text-white/80 text-lg mt-8 max-w-2xl leading-relaxed">
          {project.descripcion}
        </p>
      </div>
    </article>
  </main>
</Layout>